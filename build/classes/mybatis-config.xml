<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0//EN" "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <environments default="development">
        <environment id="development">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <property name="driver" value="com.mysql.cj.jdbc.Driver"/>
                <property name="url" value="jdbc:mysql://localhost:3306/volunteer_db?useSSL=false&amp;serverTimezone=Asia/Shanghai&amp;characterEncoding=utf8mb4"/>
                <property name="username" value="root"/>
                <property name="password" value="root"/>
            </dataSource>
        </environment>
    </environments>
    <mappers>
        <mapper resource="com/mybatis/AuserMapper.xml"/>
        <mapper resource="com/mybatis/VolunteerMapper.xml"/>
        <mapper resource="com/mybatis/ActivityTypeMapper.xml"/>
        <mapper resource="com/mybatis/ActivityMapper.xml"/>
        <mapper resource="com/mybatis/EnrollmentMapper.xml"/>
        <mapper resource="com/mybatis/AttendanceMapper.xml"/>
        <mapper resource="com/mybatis/ServiceRecordMapper.xml"/>
        <mapper resource="com/mybatis/PointsMapper.xml"/>
        <mapper resource="com/mybatis/ExperienceMapper.xml"/>
        <mapper resource="com/mybatis/NoticeMapper.xml"/>
    </mappers>
</configuration>
