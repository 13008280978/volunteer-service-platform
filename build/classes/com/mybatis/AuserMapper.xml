<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.volunteer.dao.AuserDao">
    <resultMap id="AuserResult" type="com.volunteer.po.Auser">
        <id property="adminId" column="admin_id"/>
        <result property="adminName" column="admin_name"/>
        <result property="adminAccount" column="admin_account"/>
        <result property="adminPassword" column="admin_password"/>
        <result property="adminPhone" column="admin_phone"/>
        <result property="adminEmail" column="admin_email"/>
        <result property="adminStatus" column="admin_status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>
    <select id="findByAccount" resultMap="AuserResult">
        SELECT * FROM AUSER WHERE admin_account = #{adminAccount}
    </select>
    <select id="findById" resultMap="AuserResult">
        SELECT * FROM AUSER WHERE admin_id = #{adminId}
    </select>
    <select id="findAll" resultMap="AuserResult">
        SELECT * FROM AUSER ORDER BY admin_id
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="adminId">
        INSERT INTO AUSER(admin_name, admin_account, admin_password, admin_phone, admin_email)
        VALUES(#{adminName}, #{adminAccount}, #{adminPassword}, #{adminPhone}, #{adminEmail})
    </insert>
    <update id="update">
        UPDATE AUSER
        <set>
            <if test="adminName != null">admin_name = #{adminName},</if>
            <if test="adminPhone != null">admin_phone = #{adminPhone},</if>
            <if test="adminEmail != null">admin_email = #{adminEmail},</if>
        </set>
        WHERE admin_id = #{adminId}
    </update>
    <update id="updateStatus">
        UPDATE AUSER SET admin_status = #{adminStatus} WHERE admin_id = #{adminId}
    </update>
</mapper>
