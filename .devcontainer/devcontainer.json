{
  "name": "JSP Project Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "8",
      "installMaven": true
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Tomcat",
      "onAutoForward": "notify"
    }
  }
}
